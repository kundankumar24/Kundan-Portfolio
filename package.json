{
  "name": "portfolio-enhancement",
  "version": "1.0.0",
  "description": "Modern portfolio website with advanced features and performance optimization",
  "type": "module",
  "main": "src/js/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode production && open dist/stats.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write src/**/*.{js,css,html}",
    "format:check": "prettier --check src/**/*.{js,css,html}",
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean && npm run lint && npm run test:run",
    "postbuild": "npm run validate:build",
    "validate:build": "node scripts/validate-build.js",
    "validate:quality": "node scripts/validate-code-quality.js",
    "deploy:preview": "npm run build && npm run preview",
    "ci": "npm run lint && npm run format:check && npm run test:run && npm run build"
  },
  "keywords": [
    "portfolio",
    "website",
    "vite",
    "javascript",
    "css",
    "performance",
    "accessibility"
  ],
  "author": "Portfolio Owner",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.5.3",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "jspdf": "^4.2.0"
  }
}
